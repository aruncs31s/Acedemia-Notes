views:
  - type: table
    name: Table
    filters:
      and:
        - file.tags.contains("supply")
    order:
      - file.name
      - ExamDate
      - passed
      - file.tags
      - status
      - file.backlinks
    columnSize:
      file.name: 188
      note.passed: 130
      file.tags: 132
      note.status: 202
